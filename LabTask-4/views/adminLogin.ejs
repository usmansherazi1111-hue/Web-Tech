<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">

    <title>Admin Login</title>

    <link rel="stylesheet" href="/admin.css">

</head>

<body>

    <div class="login-container">

        <form action="/admin/login" method="POST" class="login-form">

            <h1>Admin Login</h1>

            <input
                type="password"
                name="password"
                placeholder="Enter Admin Password"
                required
            >

            <button type="submit">
                Login
            </button>

        </form>

    </div>

</body>

</html>