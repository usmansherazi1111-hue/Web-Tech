<!DOCTYPE html>
<html>

<head>

    <title>Admin Login</title>

    <link rel="stylesheet" href="/css/admin.css">

</head>

<body>

    <div class="login-container">

        <form action="/admin/login" method="POST">

            <h1>Admin Login</h1>

            <input 
                type="email"
                name="email"
                placeholder="Email"
                required
            >

            <input 
                type="password"
                name="password"
                placeholder="Password"
                required
            >

            <button type="submit">
                Login
            </button>

        </form>

    </div>

</body>

</html>