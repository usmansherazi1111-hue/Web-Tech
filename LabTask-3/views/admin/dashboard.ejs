<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">

    <title>Admin Dashboard</title>

    <link rel="stylesheet" href="/admin.css">

</head>

<body>

    <div class="admin-container">

        <!-- SIDEBAR -->

        <div class="sidebar">

            <h2>Admin Panel</h2>

            <a href="/admin/dashboard">Dashboard</a>

            <a href="/admin/add">Add Product</a>

            <a href="/products?page=1">View Store</a>

            <a href="/admin/logout">Logout</a>

        </div>

        <!-- MAIN CONTENT -->

        <div class="main-content">

            <h1>Product Management</h1>

            <table>

                <thead>

                    <tr>

                        <th>Image</th>
                        <th>Name</th>
                        <th>Price</th>
                        <th>Category</th>
                        <th>Stock</th>
                        <th>Rating</th>
                        <th>Actions</th>

                    </tr>

                </thead>

                <tbody>

                    <% products.forEach(product => { %>

                        <tr>

                            <td>

                                <img
                                    src="<%= product.image %>"
                                    width="80"
                                    height="80"
                                    style="object-fit: cover; border-radius: 8px;"
                                >

                            </td>

                            <td><%= product.name %></td>

                            <td>$<%= product.price %></td>

                            <td><%= product.category %></td>

                            <td><%= product.stock %></td>

                            <td>⭐ <%= product.rating %></td>

                            <td>

                                <a
                                    href="/admin/edit/<%= product._id %>"
                                    class="edit-btn"
                                >
                                    Edit
                                </a>

                                <form
                                    action="/admin/delete/<%= product._id %>?_method=DELETE"
                                    method="POST"
                                    style="display:inline;"
                                    onsubmit="return confirm('Are you sure you want to delete this product?')"
                                >

                                    <button
                                        type="submit"
                                        class="delete-btn"
                                    >
                                        Delete
                                    </button>

                                </form>

                            </td>

                        </tr>

                    <% }) %>

                </tbody>

            </table>

        </div>

    </div>

</body>

</html>